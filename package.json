{
  "name": "grapplehook-cli",
  "version": "0.1.1",
  "description": "Download videos from the command line (yt-dlp + ffmpeg + aria2c), with an optional editor-friendly mp4 transcode.",
  "type": "module",
  "bin": {
    "grapplehook": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "prepublishOnly": "npm run build",
    "format": "prettier . --write",
    "lint": "eslint --fix",
    "bonita": "pnpm run lint && pnpm run format"
  },
  "keywords": [
    "youtube",
    "youtube-downloader",
    "yt-dlp",
    "ffmpeg",
    "aria2c",
    "cli",
    "mp4",
    "transcode",
    "video",
    "downloader"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rusty-grapplehook/grapplehook-cli.git"
  },
  "bugs": {
    "url": "https://github.com/rusty-grapplehook/grapplehook-cli/issues"
  },
  "homepage": "https://github.com/rusty-grapplehook/grapplehook-cli#readme",
  "author": "kitsupanic",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "grapplehook-core": "^0.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.1",
    "@eslint/markdown": "^8.0.3",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "prettier": "^3.9.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-sort-json": "^4.2.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  }
}
